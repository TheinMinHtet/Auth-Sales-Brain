generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  DEVELOPER
  SHOP_OWNER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(SHOP_OWNER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  shop         Shop?
}

model Shop {
  id               String    @id @default(cuid())
  shopId           String    @unique
  businessName     String
  ownerName        String?
  description      String?
  businessCategory String[]
  targetAudience   String?
  ageGroup         String?
  businessGoal     String?
  challenges       String?
  marketingMethods String[]
  paymentInfo      String
  deliveryInfo     String
  faq              String?
  policies         String?
  botSystemPrompt  String?
  botTone          String    @default("friendly")
  isActive         Boolean   @default(true)
  ownerId          String    @unique
  owner            User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  products         Product[]
  orders           Order[]
  chatSessions     ChatSession[]
  analytics        ShopAnalytics[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([shopId])
}

model Product {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Float
  imageUrl    String?
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderItems  OrderItem[]

  @@index([shopId])
}

model Order {
  id            String      @id @default(cuid())
  shopId        String
  shop          Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerName  String
  customerEmail String
  customerPhone String?
  address       String
  total         Float
  status        OrderStatus @default(PENDING)
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([shopId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

model ChatSession {
  id        String        @id @default(cuid())
  shopId    String
  shop      Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  sessionId String
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([shopId, sessionId])
  @@index([shopId])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  createdAt DateTime    @default(now())

  @@index([sessionId])
}

model ShopAnalytics {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  eventType   String
  metadata    String?
  createdAt   DateTime @default(now())

  @@index([shopId, eventType])
  @@index([createdAt])
}
